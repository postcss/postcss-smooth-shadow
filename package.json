{
  "name": "postcss-smooth-shadow",
  "version": "0.0.0",
  "description": "PostCSS plugin to generate more realistic shadows",
  "keywords": [
    "postcss",
    "css",
    "postcss-plugin",
    "shadow",
    "smooth"
  ],
  "scripts": {
    "unit": "node --test index.test.js",
    "test:coverage": "c8 node --test index.test.js",
    "test:lint": "eslint .",
    "test": "pnpm run /^test:/"
  },
  "author": "Andrey Sitnik <andrey@sitnik.ru>",
  "license": "MIT",
  "repository": "postcss/postcss-smooth-shadow",
  "engines": {
    "node": "^20.0 || ^22.0 || >=24.0"
  },
  "funding": [
    {
      "type": "opencollective",
      "url": "https://opencollective.com/postcss/"
    },
    {
      "type": "github",
      "url": "https://github.com/sponsors/ai"
    }
  ],
  "peerDependencies": {
    "postcss": "^8.2.14"
  },
  "devDependencies": {
    "@logux/eslint-config": "^56.1.0",
    "actions-up": "^1.4.1",
    "c8": "^10.1.3",
    "clean-publish": "^5.2.2",
    "eslint": "^9.37.0",
    "multiocular": "^0.8.1",
    "postcss": "^8.5.6"
  },
  "prettier": {
    "arrowParens": "avoid",
    "jsxSingleQuote": false,
    "quoteProps": "consistent",
    "semi": false,
    "singleQuote": true,
    "trailingComma": "none"
  },
  "c8": {
    "exclude": [
      "*.test.*"
    ],
    "lines": 100,
    "reporter": "lcov",
    "check-coverage": true
  },
  "clean-publish": {
    "cleanDocs": true
  }
}
